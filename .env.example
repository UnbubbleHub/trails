# --- Telegram ---
# Bot token from @BotFather
TELEGRAM_TRAILS_API_SECRET=
# Arbitrary secret; Telegram echoes it back in the X-Telegram-Bot-Api-Secret-Token header
TELEGRAM_TRAILS_WEBHOOK_SECRET=
# Access allowlist. Comma-separated Telegram numeric user IDs (e.g. "12345,67890"),
# or "*" to allow everyone. Unset/empty means no one is allowed.
TRAILS_ALLOWED_USER_IDS=

# --- OpenAI ---
OPENAI_API_KEY=

# --- Exa (news search) ---
EXA_API_KEY=

# --- Firebase (Admin SDK) ---
# base64 of the service-account JSON: `base64 -i service-account.json`
FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=

# --- Cron ---
# Bearer token required by GET /api/cron/trail-notifications
CRON_SECRET=
# Max subscriptions processed per cron run (default 40)
TOPIC_CRON_MAX_SUBS_PER_RUN=40

# --- Repository backend (optional; default: firestore) ---
# TRAILS_REPO_BACKEND=firestore
